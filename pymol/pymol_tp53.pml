png derived\figures/view4_dna_interface.png, width=1200, height=900, dpi=150, ray=1

# ============================================================
# Zinc ions
# ============================================================
select zinc_ions, resname ZN
show spheres, zinc_ions
color grey50, zinc_ions
set sphere_scale, 0.5, zinc_ions

# ============================================================
# Final state for interactive exploration
# ============================================================
hide surface
set transparency, 0
color grey70, protein
color firebrick, hotspots
color yellow, key_contact
color magenta, key_structural
show sticks, key_structural
show sticks, key_contact
show sticks,  dna
color cyan,   dna
zoom protein

print("""
=== TP53 PyMOL session ready ===
Selections defined:
  protein       -- chain A, cartoon
  dna           -- chain C, sticks (cyan)
  hotspots      -- FoldX hotspot positions (red)
  key_structural -- R175/C176/C238/C242/G245/R249/R282/C135 (magenta sticks)
  key_contact   -- R248/R273 (yellow sticks, contact mutants)
  key_outlier   -- H115 (orange, force-field artefact)
  zinc_ions     -- Zn2? spheres

Views saved:
  derived\figures/view1_ddg_spectrum.png
  derived\figures/view2_hotspot_binary.png
  derived\figures/view3_key_residues.png
  derived\figures/view4_dna_interface.png
""")
