# ============================================================
# pymol_tp53.pml  --  TP53 structural analysis visualisation
# Generated by make_pymol_script.py
# Run:  pymol pymol_tp53.pml
# ============================================================

# 0. Setup
load 3kz8.pdb1, tp53
bg_color white
set ray_shadows, 0
set antialias, 2
set ray_trace_mode, 1
hide everything

# Show only chain A (protein) and chain C (DNA)
select protein, chain A and tp53
select dna,     chain C and tp53

show cartoon, protein
show sticks,  dna
color grey80, protein
color cyan,   dna

# ============================================================
# VIEW 1 -- Mean DDG per position (blue=stable -> red=hotspot)
# ============================================================
set_color ddg_96, [0.012, 0.012, 1.000]
color ddg_96, chain A and resi 96
