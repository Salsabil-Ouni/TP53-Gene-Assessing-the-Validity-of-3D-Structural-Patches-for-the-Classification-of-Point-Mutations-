# Add a pseudo colour bar legend (select key residues for reference)
# Blue  = DDG ~ 0  |  White = ~7.5  |  Red = ~15+ kcal/mol

set_view (\
   0.8,  -0.4,   0.4,\
  -0.1,   0.8,   0.6,\
  -0.6,  -0.4,   0.7,\
   0.0,   0.0, -120.0,\
   0.0,   0.0,   0.0,\
  80.0,  160.0,  -20.0)

png derived\figures/view1_ddg_spectrum.png, width=1200, height=900, dpi=150, ray=1

# ============================================================
# VIEW 2 -- Hotspot (red) vs non-hotspot (grey)
# ============================================================
color grey70, protein
select hotspots, chain A and resi 
color firebrick, hotspots

png derived\figures/view2_hotspot_binary.png, width=1200, height=900, dpi=150, ray=1

# ============================================================
# VIEW 3 -- Key residue annotations as sticks
# ============================================================
color grey70, protein
color cyan,   dna
select key_structural, chain A and resi 135+176+175+238+242+245+282+249
show sticks, key_structural
color magenta, key_structural
select key_contact, chain A and resi 248+273
show sticks, key_contact
color yellow, key_contact
select key_outlier, chain A and resi 115
show sticks, key_outlier
color orange, key_outlier
label chain A and resi 135 and name CA, "C135"
label chain A and resi 176 and name CA, "C176"
label chain A and resi 175 and name CA, "R175"
label chain A and resi 238 and name CA, "C238"
label chain A and resi 242 and name CA, "C242"
label chain A and resi 245 and name CA, "G245"
label chain A and resi 282 and name CA, "R282"
label chain A and resi 249 and name CA, "R249"
label chain A and resi 248 and name CA, "R248"
label chain A and resi 273 and name CA, "R273"
set label_size, 14
set label_color, black

png derived\figures/view3_key_residues.png, width=1200, height=900, dpi=150, ray=1

# ============================================================
# VIEW 4 -- Surface coloured by DNA proximity
#          Close (< 8 A) = yellow, Far (> 25 A) = blue
# ============================================================
show surface, protein
set transparency, 0.2, protein
set_color dna_96, [0.248, 0.248, 0.752]
